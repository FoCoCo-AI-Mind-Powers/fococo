# Environment Variables for FoCoCo AI Integration
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_organization_id_here

# Gemini AI Configuration
# The Gemini API key is stored in Google Cloud Secret Manager as `GEMINI_KEY_APP`
# and consumed only by Cloud Functions. The client uses Firebase AI Logic
# (App Check authenticated) — no raw key is shipped to the app.

# Cartesia Voice — keys and agent ids live server-side only:
# - Secret Manager: CARTESIA_API (TTS/STT + Line access-token minting)
# - Secret Manager: GEMINI_KEY_APP (GolfChat callable + Line agent reasoning)
# - Firebase params (firebase/functions/.env.<project>):
#     CARTESIA_LINE_AGENT_ID=<uuid from `cartesia deploy`>
#     CARTESIA_PRONUNCIATION_DICT_ID=<optional dict from Cartesia playground>
# Line agent env: see cartesia_line_agent/.env.example (`cartesia env set --from .env`)

# Development Settings
FLUTTER_ENV=development

# Note: Never commit your actual .env file to version control
# The .env file should be added to .gitignore 