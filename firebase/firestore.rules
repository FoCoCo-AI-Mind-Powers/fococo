rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user owns the resource (userId matches auth.uid)
    function isOwner(userId) {
      return isAuthenticated() && userId == request.auth.uid;
    }

    function ownsResourceDoc() {
      return isAuthenticated() &&
             (resource.data.user_id == request.auth.uid ||
              resource.data.userId == request.auth.uid);
    }
    
    // App settings - public read access for configuration
    match /app_settings/{document} {
      allow read: if true;
      allow write: if false; // Only admin can write app settings
    }
    
    match /user/{document} {
      allow create: if request.auth != null;
      // Allow users to read their own user document
      allow read: if request.auth != null && request.auth.uid == document;
      allow write: if request.auth != null && request.auth.uid == document;
      allow delete: if request.auth != null && request.auth.uid == document;
    }

    match /data_export_requests/{document} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /account_deletion_requests/{document} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if false;
    }

    match /support_submissions/{document} {
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.type in ['bug', 'feedback'] &&
        request.resource.data.message is string &&
        request.resource.data.message.size() >= 10 &&
        request.resource.data.status == 'open';
      allow read, update, delete: if false;
    }
    
    match /golf_rounds/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /mental_sessions/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    match /ai_insights/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }

    // Derived intelligence collections - owner readable, backend write-only.
    match /round_summaries/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /round_insights/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /user_patterns/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /coaching_state/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /training_summary/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /chat_summary/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /context_cache/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }

    match /insight_history/{document} {
      allow read: if ownsResourceDoc();
      allow create, update, delete: if false;
    }
    
    // Subscriptions: owner is identified by userId (camelCase) or legacy user_id.
    function subscriptionDocOwnedByAuth() {
      return request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         resource.data.user_id == request.auth.uid);
    }

    function subscriptionWriteOwnedByAuth() {
      return request.auth != null &&
        (request.resource.data.userId == request.auth.uid ||
         request.resource.data.user_id == request.auth.uid);
    }

    match /user_subscriptions/{document} {
      allow create: if request.auth != null &&
                     request.resource.data.userId == request.auth.uid;
      allow read: if subscriptionDocOwnedByAuth();
      allow update: if subscriptionDocOwnedByAuth() &&
                     subscriptionWriteOwnedByAuth();
      allow delete: if subscriptionDocOwnedByAuth();
    }
    
    // AI Memory Service - Enhanced conversation memory and NLP analysis
    match /ai_memory/{document} {
      allow create: if request.auth != null && request.auth.uid == document;
      allow read: if request.auth != null && request.auth.uid == document;
      allow write: if request.auth != null && request.auth.uid == document;
      allow delete: if request.auth != null && request.auth.uid == document;
    }
    
    // Conversation Sessions - For AI memory management
    match /conversation_sessions/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Voice Chat Sessions - For voice chat conversation management
    match /voice_chat_sessions/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Voice Chat Messages - For individual voice chat messages
    match /voice_chat_messages/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // User Voice Chat Stats - For voice chat analytics
    match /user_voice_chat_stats/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // ============================================================================
    // COACHING MODULES - PRODUCTION SECURITY RULES
    // ============================================================================
    
    // Coaching Modules - Public read access for all authenticated users, admin-only writes
    match /coaching_modules/{document} {
      allow read: if request.auth != null; // All authenticated users can read coaching modules
      allow create: if false; // Only admins can create modules (via Admin SDK/Cloud Functions)
      allow update: if false; // Only admins can update modules (via Admin SDK/Cloud Functions)  
      allow delete: if false; // Only admins can delete modules (via Admin SDK/Cloud Functions)
    }
    
    // Module Progress Tracking - User-specific progress and completion data
    match /user_module_progress/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Module Ratings & Reviews - User feedback on coaching modules
    match /module_reviews/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null; // Anyone can read reviews
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Training Plans - User-specific training plans
    match /training_plans/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Content Analytics - Module usage and performance metrics
    match /module_analytics/{document} {
      allow read: if false; // Analytics are read via Cloud Functions only
      allow write: if false; // Analytics are written via Cloud Functions only
    }
    
    // ============================================================================
    // END COACHING MODULES RULES
    // ============================================================================
    
    // ============================================================================
    // MINDCOACH AI SESSIONS - PRODUCTION SECURITY RULES
    // ============================================================================
    
    // MindCoach Sessions - User-specific AI coaching sessions
    match /mindcoach_sessions/{document} {
      // Immutable write path: backend only (Admin SDK bypasses rules).
      allow create: if false;
      allow read: if request.auth != null &&
                   (resource.data.user_id == request.auth.uid ||
                    resource.data.userId == request.auth.uid);
      allow update: if false;
      allow delete: if false;
    }
    
    // MindCoach Templates - Read-only for authenticated users, admin-only writes
    match /mindcoach_templates/{document} {
      allow read: if request.auth != null; // All authenticated users can read templates
      allow create: if false; // Only admins can create templates (via Admin SDK/Cloud Functions)
      allow update: if false; // Only admins can update templates (via Admin SDK/Cloud Functions)
      allow delete: if false; // Only admins can delete templates (via Admin SDK/Cloud Functions)
    }
    
    // MindCoach Content Library - Read-only for authenticated users, admin-only writes
    match /mindcoach_content_library/{document} {
      allow read: if request.auth != null; // All authenticated users can read content library
      allow create: if false; // Only admins can create content (via Admin SDK/Cloud Functions)
      allow update: if false; // Only admins can update content (via Admin SDK/Cloud Functions)
      allow delete: if false; // Only admins can delete content (via Admin SDK/Cloud Functions)
    }

    // MindCoach Scenario Tags - Read-only for authenticated users, admin-only writes.
    match /mindcoach_scenario_tags/{document} {
      allow read: if request.auth != null;
      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }

    // MindCoach session runs - owner scoped read/write.
    match /mindcoach_session_runs/{document} {
      allow create: if request.auth != null &&
                     request.resource.data.user_id == request.auth.uid;
      allow read: if request.auth != null &&
                   resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null &&
                     resource.data.user_id == request.auth.uid &&
                     request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null &&
                     resource.data.user_id == request.auth.uid;
    }

    // MindCoach favorites - owner scoped read/write.
    match /mindcoach_favorites/{document} {
      allow create: if request.auth != null &&
                     request.resource.data.user_id == request.auth.uid;
      allow read: if request.auth != null &&
                   resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null &&
                     resource.data.user_id == request.auth.uid &&
                     request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null &&
                     resource.data.user_id == request.auth.uid;
    }

    // MindCoach user profiles - owner scoped read/write.
    match /mindcoach_user_profiles/{document} {
      allow create: if request.auth != null &&
                     request.resource.data.user_id == request.auth.uid &&
                     document == request.auth.uid;
      allow read: if request.auth != null &&
                   document == request.auth.uid;
      allow update: if request.auth != null &&
                     document == request.auth.uid &&
                     resource.data.user_id == request.auth.uid &&
                     request.resource.data.user_id == request.auth.uid;
      allow delete: if request.auth != null &&
                     document == request.auth.uid;
    }
    
    // AI Validator Logs - Backend-only writes, admin-only reads
    match /ai_validator_logs/{document} {
      allow read: if false; // Admin-only reads (via Cloud Functions/Admin SDK)
      allow create: if false;
      allow update: if false; // Logs are immutable
      allow delete: if false; // Logs should not be deleted
    }
    
    // ============================================================================
    // END MINDCOACH AI SESSIONS RULES
    // ============================================================================
    
    // ============================================================================
    // AI USAGE TRACKING - PRODUCTION SECURITY RULES
    // ============================================================================
    
    // AI Usage Tracking - Track AI token usage and costs per user
    match /ai_usage_tracking/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if false; // Usage records are immutable
      allow delete: if false; // Usage records should not be deleted
    }
    
    // User Tokens - Track user token balances and limits
    match /user_tokens/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if false; // Token records should not be deleted
    }
    
    // Token Purchases - Track token purchase transactions
    match /token_purchases/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if false; // Purchase records are immutable
      allow delete: if false; // Purchase records should not be deleted
    }
    
    // ============================================================================
    // END AI USAGE TRACKING RULES
    // ============================================================================
    
    // ============================================================================
    // ASSESSMENT RESULTS - PRODUCTION SECURITY RULES
    // ============================================================================
    
    // Assessment Results - Store VARK assessment results per user
    match /assessment_results/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // ============================================================================
    // END ASSESSMENT RESULTS RULES
    // ============================================================================
    
    // FoCoMap Collections – open read/write for authenticated users
    match /round_logs/{document} {
      allow read, write: if request.auth != null;
    }
    
    match /shot_logs/{document} {
      allow read, write: if request.auth != null;
    }

    // CaddyPlay session capture collections – open read/write for authenticated users
    match /caddyplay_sessions/{document} {
      allow read, write: if request.auth != null;

      // Hole control/edit docs inside each session
      match /holes/{holeNumber} {
        allow read, write: if request.auth != null;
      }
    }

    match /caddyplay_logs/{document} {
      allow read, write: if request.auth != null;
    }
    
    // Notifications - User-specific notifications from push notifications or system
    match /notifications/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Dashboard Data - User-specific dashboard analytics and summaries
    match /dashboard_data/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Home Data - User-specific home page data cache
    match /home_data/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
    
    // Scorecards - User-specific golf scorecard data (Prime tier feature)
    match /scorecards/{document} {
      allow create: if request.auth != null && 
                     request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && 
                   resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && 
                     resource.data.userId == request.auth.uid &&
                     request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && 
                     resource.data.userId == request.auth.uid;
    }
  }
}
