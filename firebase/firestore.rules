rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // App settings - public read access for configuration
    match /app_settings/{document} {
      allow read: if true;
      allow write: if false; // Only admin can write app settings
    }
    
    match /user/{document} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (request.auth.uid == document || request.auth.token.email_verified);
      allow write: if request.auth != null && request.auth.uid == document;
      allow delete: if request.auth != null && request.auth.uid == document;
    }
    
    match /golf_rounds/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    match /mental_sessions/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    match /ai_insights/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    match /user_subscriptions/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    // AI Memory Service - Enhanced conversation memory and NLP analysis
    match /ai_memory/{document} {
      allow create: if request.auth != null && request.auth.uid == document;
      allow read: if request.auth != null && request.auth.uid == document;
      allow write: if request.auth != null && request.auth.uid == document;
      allow delete: if request.auth != null && request.auth.uid == document;
    }
    
    // Conversation Sessions - For AI memory management
    match /conversation_sessions/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    // Voice Chat Sessions - For voice chat conversation management
    match /voice_chat_sessions/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    // Voice Chat Messages - For individual voice chat messages
    match /voice_chat_messages/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    // User Voice Chat Stats - For voice chat analytics
    match /user_voice_chat_stats/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    // ============================================================================
    // COACHING MODULES - PRODUCTION SECURITY RULES
    // ============================================================================
    
    // Coaching Modules - Public read access for all authenticated users, admin-only writes
    match /coaching_modules/{document} {
      allow read: if request.auth != null; // All authenticated users can read coaching modules
      allow create: if false; // Only admins can create modules (via Admin SDK/Cloud Functions)
      allow update: if false; // Only admins can update modules (via Admin SDK/Cloud Functions)  
      allow delete: if false; // Only admins can delete modules (via Admin SDK/Cloud Functions)
    }
    
    // Module Progress Tracking - User-specific progress and completion data
    match /user_module_progress/{document} {
      allow create: if request.auth != null && 
                     request.auth.token.email_verified && 
                     request.auth.uid == resource.data.userId;
      allow read: if request.auth != null && 
                   request.auth.uid == resource.data.userId;
      allow write: if request.auth != null && 
                    request.auth.token.email_verified && 
                    request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && 
                     request.auth.token.email_verified && 
                     request.auth.uid == resource.data.userId;
    }
    
    // Module Ratings & Reviews - User feedback on coaching modules
    match /module_reviews/{document} {
      allow create: if request.auth != null && 
                     request.auth.token.email_verified &&
                     request.auth.uid == resource.data.userId;
      allow read: if request.auth != null; // Anyone can read reviews
      allow write: if request.auth != null && 
                    request.auth.token.email_verified && 
                    request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && 
                     request.auth.token.email_verified && 
                     request.auth.uid == resource.data.userId;
    }
    
    // Content Analytics - Module usage and performance metrics
    match /module_analytics/{document} {
      allow read: if false; // Analytics are read via Cloud Functions only
      allow write: if false; // Analytics are written via Cloud Functions only
    }
    
    // ============================================================================
    // END COACHING MODULES RULES
    // ============================================================================
    
    // FoCoMap Collections - Enhanced security for golf data
    match /round_logs/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
    
    match /shot_logs/{document} {
      allow create: if request.auth != null && request.auth.token.email_verified;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && request.auth.token.email_verified && resource.data.userId == request.auth.uid;
    }
  }
}