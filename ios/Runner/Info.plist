			<string>fococo.com</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>fococo</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>FirebaseAppCheckProviderFactory</key>
	<string>NO</string>
	<key>FirebaseAppCheckTokenAutoRefreshEnabled</key>
	<false/>
	<!--
	  Enabled natively so Crashlytics is live from process start and can catch
	  crashes that happen during native plugin init (the launch window where
	  TestFlight crashes have been disappearing). Debug builds still suppress
	  collection at runtime via BootPhaseLogger.configureCrashlyticsCollection
	  (gated on kReleaseMode), so debug noise stays out of Firebase.
	-->
	<key>FirebaseCrashlyticsCollectionEnabled</key>
	<true/>
	<key>FirebaseAppDelegateProxyEnabled</key>
	<false/>
	<key>FirebaseMessagingAutoInitEnabled</key>
	<false/>
	<key>FlutterDeepLinkingEnabled</key>
	<true/>
	<key>NSSupportsLiveActivities</key>
	<true/>
	<key>GMSApiKey</key>
	<string>AIzaSyAYkQKNgnVZUj5Yd9C3Iyjjg0lwc4TJXuA</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>NSCameraUsageDescription</key>
	<string>FoCoCo uses camera access to enable video-based coaching sessions, capture swing analysis footage, and provide visual feedback for your mental performance training.</string>
	<key>NSFaceIDUsageDescription</key>
	<string>FoCoCo uses Face ID to sign you in quickly.</string>
	<key>NSLocationAlwaysAndWhenInUseUsageDescription</key>
	<string>FoCoCo uses your location to identify your course and provide relevant context.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>FoCoCo uses your location to identify your course and provide relevant context.</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>FoCoCo uses the microphone for JustTalk round capture, GolfChat voice reflection, and MindCoach audio sessions.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>FoCoCo can save coaching progress screenshots and achievement images to your photo library for easy sharing and reference.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>FoCoCo needs access to your photo library to allow you to select and upload profile pictures and save coaching progress images.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>FoCoCo uses speech recognition to provide voice-controlled navigation, transcribe your mental performance notes, and analyze speech patterns for personalized coaching insights.</string>
	<key>NSUserNotificationsUsageDescription</key>
	<string>FoCoCo sends notifications to remind you of daily coaching sessions, notify you when AI insights are ready, and help maintain your mental training streaks.</string>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>
